{
  "name": "cyez-ls101",
  "version": "0.2.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "yarn run typecheck:node && yarn run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "electron-vite preview",
    "dev": "yarn run predev && chcp 65001 && electron-vite dev",
    "build": "yarn run prebuild && yarn run lint && yarn run typecheck && electron-vite build",
    "setup": "node scripts/setup.js",
    "postinstall": "electron-builder install-app-deps && node scripts/setup.js",
    "predev": "node scripts/setup.js",
    "prebuild": "node scripts/setup.js",
    "build:unpack": "node build.js --local --dir",
    "build:win": "node build.js --local --win",
    "build:dev": "node build.js --dev",
    "build:nightly": "node build.js --nightly",
    "build:release": "node build.js --release"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "adm-zip": "^0.5.17",
    "execa": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "sherpa-onnx-node": "^1.13.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-istanbul": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "archive-wasm": "^2.1.0",
    "electron": "^39.2.6",
    "electron-builder": "26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.2.6",
    "vitest": "^4.1.6"
  },
  "dependenciesMeta": {
    "electron": {
      "built": true
    },
    "esbuild": {
      "built": true
    },
    "ffmpeg-static": {
      "built": true
    }
  },
  "packageManager": "yarn@4.15.0"
}
